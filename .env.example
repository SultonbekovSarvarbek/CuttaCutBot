# Токен бота от @BotFather (обязательно)
BOT_TOKEN=123456:ABCDEF-your-token-here

# Лимит размера отправляемого файла в МБ.
# Официальный Bot API = 50. Локальный Bot API server = до 2000.
MAX_FILE_MB=50

# Потолок качества видео по высоте (px).
MAX_HEIGHT=720

# Максимальная длина отрезка в секундах (по умолчанию 15 минут).
MAX_CLIP_SECONDS=900

# Максимум секунд на работу yt-dlp (по умолчанию 10 минут).
DOWNLOAD_TIMEOUT=600

# Сколько скачиваний может идти одновременно.
MAX_CONCURRENT_DOWNLOADS=2

# URL локального Telegram Bot API server (опционально).
# Оставь пустым, чтобы использовать официальный api.telegram.org.
# Пример: http://localhost:8081
TELEGRAM_API_URL=
